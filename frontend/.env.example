# URL of the XenoReach crm-core backend (see backend/README.md)
VITE_API_BASE_URL=http://localhost:8080

# --- Firebase (for "Continue with Google") ---
# Get these from Firebase Console > Project Settings > General > Your apps > Web app
# If left blank, "Continue with Google" falls back to a dev-mode prompt
# (no Firebase project required to demo the app end-to-end).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
