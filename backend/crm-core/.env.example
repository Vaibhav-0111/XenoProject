# --- Server ---
PORT=8080

# --- Database (Neon / Postgres) ---
DATABASE_URL=jdbc:postgresql://localhost:5432/xenoreach
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# --- JWT ---
JWT_SECRET=change-this-super-secret-key-min-32-chars-long-please
JWT_EXPIRATION_MS=86400000

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000

# --- Channel Simulator ---
CHANNEL_SIMULATOR_URL=http://localhost:8081

# --- AI Provider: gemini | openai | mock ---
AI_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Firebase Admin (Google Sign-In verification) ---
FIREBASE_ENABLED=false
FIREBASE_CREDENTIALS_BASE64=
